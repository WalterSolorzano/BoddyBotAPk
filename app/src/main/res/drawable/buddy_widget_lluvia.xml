<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    <!-- Rainy Background: Gray sky -->
    <path
        android:fillColor="#90A4AE"
        android:pathData="M0,0 h200 v200 h-200 z"/>
    
    <!-- Rain drops -->
    <path
        android:strokeColor="#CFD8DC"
        android:strokeWidth="2"
        android:pathData="M40,20 l-10,20 M160,30 l-10,20 M120,50 l-10,20 M30,140 l-10,20 M180,150 l-10,20" />
    
    <!-- Buddy Body / Head -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M100,160 a50,50 0 1,0 0,-100 a50,50 0 1,0 0,100" />
    <path
        android:strokeColor="#2C3E50"
        android:strokeWidth="4"
        android:pathData="M100,160 a50,50 0 1,0 0,-100 a50,50 0 1,0 0,100" />

    <!-- Ears -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#2C3E50"
        android:strokeWidth="4"
        android:pathData="M65,85 a15,15 0 1,0 0,-30 a15,15 0 1,0 0,30" />
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#2C3E50"
        android:strokeWidth="4"
        android:pathData="M135,85 a15,15 0 1,0 0,-30 a15,15 0 1,0 0,30" />
        
    <!-- Snout -->
    <path
        android:fillColor="#F1EEE5"
        android:strokeColor="#2C3E50"
        android:strokeWidth="3"
        android:pathData="M85,120 a15,10 0 1,0 30,0 a15,10 0 1,0 -30,0" />
    <!-- Nose -->
    <path
        android:fillColor="#2C3E50"
        android:pathData="M96,115 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" />

    <!-- Eyes -->
    <path
        android:fillColor="#2C3E50"
        android:pathData="M80,105 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0" />
    <path
        android:fillColor="#2C3E50"
        android:pathData="M108,105 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0" />

    <!-- Yellow Umbrella / Rain Hat (Cap) -->
    <path
        android:fillColor="#FBC02D"
        android:strokeColor="#2C3E50"
        android:strokeWidth="4"
        android:pathData="M50,70 Q100,20 150,70 Z" />

    <!-- Umbrella handle -->
    <path
        android:strokeColor="#2C3E50"
        android:strokeWidth="4"
        android:pathData="M150,70 L160,140 Q165,150 170,140" />

    <!-- Mouth straight (neutral/worried about rain) -->
    <path
        android:strokeColor="#2C3E50"
        android:strokeWidth="3"
        android:pathData="M95,126 l10,0" />
</vector>
